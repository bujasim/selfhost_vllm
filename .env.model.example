# Copy this file to .env.model and change values there.
# Environment variables passed in the shell still override these values.

MODEL=Qwen/Qwen3.5-0.8B
HOST=0.0.0.0
PORT=8000
MAX_MODEL_LEN=12288
GPU_MEMORY_UTILIZATION=0.92
MAX_NUM_BATCHED_TOKENS=16384
TENSOR_PARALLEL_SIZE=1
REASONING_PARSER=qwen3
LANGUAGE_MODEL_ONLY=1
TRUST_REMOTE_CODE=0
ENABLE_PREFIX_CACHING=1
